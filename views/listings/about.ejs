<% layout("/layouts/boilerplate") %>

<!-- Hero -->
<div class="about-hero">
  <div class="container">
    <h1>About Recipe Haven</h1>
    <p>Your ultimate destination for discovering, sharing, and enjoying delicious recipes from around the world.</p>
  </div>
</div>

<div class="container" style="max-width:860px;padding:64px 20px 80px;">

  <!-- Mission -->
  <div class="mission-card mb-5">
    <h3><i class="fa-solid fa-bullseye me-2"></i>Our Mission</h3>
    <p style="color:var(--dark);font-size:0.95rem;line-height:1.85;margin:0;">
      At Recipe Haven, we believe that cooking is an art meant to be shared. Whether you're an experienced chef or just starting out in the kitchen, our platform is designed to inspire and connect food lovers everywhere — from mouth-watering appetizers to decadent desserts.
    </p>
  </div>

  <!-- What We Do -->
  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="why-card h-100">
        <div class="why-icon"><i class="fa-solid fa-magnifying-glass"></i></div>
        <h5>Discover</h5>
        <p>Explore thousands of recipes from different cuisines and cultures around the globe.</p>
      </div>
    </div>
    <div class="col-md-6">
      <div class="why-card h-100">
        <div class="why-icon"><i class="fa-solid fa-share-nodes"></i></div>
        <h5>Share</h5>
        <p>Publish your own culinary creations and get feedback from our vibrant community.</p>
      </div>
    </div>
    <div class="col-md-6">
      <div class="why-card h-100">
        <div class="why-icon"><i class="fa-solid fa-graduation-cap"></i></div>
        <h5>Learn</h5>
        <p>Pick up new cooking techniques, tips, and flavour combinations from expert home cooks.</p>
      </div>
    </div>
    <div class="col-md-6">
      <div class="why-card h-100">
        <div class="why-icon"><i class="fa-solid fa-users"></i></div>
        <h5>Connect</h5>
        <p>Follow your favourite creators, like recipes, and build a community around your passion.</p>
      </div>
    </div>
  </div>

  <!-- Why Recipe Haven -->
  <div class="info-card mb-5">
    <div class="card-header-rh">
      <i class="fa-solid fa-star" style="color:var(--orange);"></i> Why Recipe Haven?
    </div>
    <div class="card-body-rh">
      <div class="feature-row">
        <div class="feature-dot"></div>
        <div>
          <h6>Diverse Recipes</h6>
          <p>An ever-growing collection of user-submitted recipes spanning every cuisine imaginable.</p>
        </div>
      </div>
      <div class="feature-row">
        <div class="feature-dot"></div>
        <div>
          <h6>Meal Planning</h6>
          <p>Plan your entire week's meals with our intuitive weekly meal planner.</p>
        </div>
      </div>
      <div class="feature-row">
        <div class="feature-dot"></div>
        <div>
          <h6>Smart Grocery Lists</h6>
          <p>Auto-generate shopping lists from any recipe or your entire weekly meal plan.</p>
        </div>
      </div>
      <div class="feature-row">
        <div class="feature-dot"></div>
        <div>
          <h6>Community-Focused</h6>
          <p>Rate, comment, follow creators, and get notifications — all within a friendly community.</p>
        </div>
      </div>
      <div class="feature-row">
        <div class="feature-dot"></div>
        <div>
          <h6>Quality &amp; Trust</h6>
          <p>Every recipe is reviewed and rated by our community, so you know it's worth making.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Quote -->
  <div style="background:linear-gradient(135deg,var(--primary-light),#FFD4B8);border-radius:var(--radius-lg);padding:40px;text-align:center;margin-bottom:40px;">
    <i class="fa-solid fa-quote-left fa-2x mb-3" style="color:var(--primary);opacity:0.4;"></i>
    <p style="font-size:1.2rem;font-weight:600;color:var(--dark);line-height:1.7;max-width:600px;margin:0 auto 16px;">
      "Thank you for visiting Recipe Haven, where every recipe tells a story, and every dish is a new adventure."
    </p>
    <div style="font-size:0.85rem;color:var(--grey);">— The Recipe Haven Team</div>
  </div>

  <!-- CTA -->
  <div style="text-align:center;">
    <a href="/listings" class="btn btn-primary btn-lg me-3">
      <i class="fa-solid fa-compass"></i> Explore Recipes
    </a>
    <a href="/listings/about/privacy" style="font-size:0.88rem;color:var(--grey);text-decoration:none;font-weight:500;">
      Privacy Policy →
    </a>
  </div>

</div>
