<!-- ── Notification & Search JS ──────────────────────────────── -->
<script>
/* ---------- Notification loading ---------- */
async function loadNotifications() {
  const content = document.getElementById('notifContent');
  if (!content) return;
  content.innerHTML = '<div class="notif-loading-state"><i class="fa-solid fa-spinner fa-spin"></i> Loading…</div>';
  try {
    const res  = await fetch('/notifications', { headers: { 'Accept': 'application/json' } });
    if (!res.ok) throw new Error('fetch failed');
    const data = await res.json();
    content.innerHTML = '';
    if (!data.notifications || data.notifications.length === 0) {
      content.innerHTML = `
        <div style="text-align:center;padding:32px 20px;color:var(--grey);">
          <i class="fa-regular fa-bell-slash fa-2x d-block mb-3" style="color:var(--border);"></i>
          <strong style="font-size:0.86rem;">All caught up!</strong>
          <div style="font-size:0.76rem;margin-top:4px;">No notifications yet.</div>
        </div>`;
      return;
    }
    const faIcons = { like: 'fa-thumbs-up', comment: 'fa-comment', follow: 'fa-user-plus' };
    data.notifications.forEach(n => {
      const div = document.createElement('div');
      div.className = `notif-item ${n.read ? '' : 'unread'}`;
      div.onclick = () => markRead(n._id, div);
      div.innerHTML = `
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <div style="width:32px;height:32px;border-radius:9px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:0.82rem;flex-shrink:0;">
            <i class="fa-solid ${faIcons[n.type] || 'fa-bell'}"></i>
          </div>
          <div style="flex:1;min-width:0;">
            <div class="notif-type-chip">${n.type}</div>
            <div style="font-size:0.81rem;color:var(--dark);margin-top:3px;line-height:1.4;">${n.message}</div>
          </div>
          ${n.read ? '' : '<div style="width:7px;height:7px;background:var(--primary);border-radius:50%;flex-shrink:0;margin-top:4px;"></div>'}
        </div>`;
      content.appendChild(div);
    });
  } catch(e) {
    content.innerHTML = '<div class="notif-loading-state" style="color:var(--red);"><i class="fa-solid fa-triangle-exclamation me-2"></i>Failed to load</div>';
  }
}

async function markRead(id, el) {
  await fetch(`/notifications/${id}/read`, { method: 'POST' });
  el.classList.remove('unread');
  el.querySelector('div[style*="background:var(--primary);border-radius:50%"]')?.remove();
}

async function markAllRead() {
  await fetch('/notifications/read-all', { method: 'POST' });
  document.querySelectorAll('.notif-item.unread').forEach(el => {
    el.classList.remove('unread');
    el.querySelector('div[style*="background:var(--primary);border-radius:50%"]')?.remove();
  });
  document.querySelectorAll('.rh-notif-badge').forEach(b => b.remove());
}

/* ---------- Mobile search toggle ---------- */
document.getElementById('mobileSearchToggle')?.addEventListener('click', function () {
  const bar = document.getElementById('mobileSearchBar');
  bar.classList.toggle('open');
  if (bar.classList.contains('open')) bar.querySelector('input')?.focus();
});

/* ---------- Navbar scroll shadow ---------- */
window.addEventListener('scroll', function () {
  document.getElementById('mainNavbar')?.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });
</script>
